@startuml Manage_Massage

header MasQ Sequence Diagram
footer Page %page% of %lastpage%

participant "Client" as client
participant "<<javaScript>>\n:server" as server
participant "<<router>>\n:massages" as routerMassages
participant "<<controllers>>\n:massages" as controllersMassages
participant "<<model>>\n:Massage" as modelMassage
database "<<MongoDB>>\n:massages" as MassagesDatabase

' ==========================================
' POST
' ==========================================
== Manage Massage (POST) ==

client->server ++:req.post('/api/massages')
server->routerMassages ++:app.use('/api/massages',massages)
routerMassages -> controllersMassages ++:createMassage()
controllersMassages->modelMassage ++:create(req.body)
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: massage
controllersMassages <-- modelMassage --:massage
controllersMassages->client --:response

newpage

' ==========================================
' GET ALL
' ==========================================
== Manage Massage (GET ALL) ==

client->server ++:req.get('/api/massages')
server->routerMassages ++:app.use('/api/massages',massages)
routerMassages -> controllersMassages ++:getMassages()
controllersMassages->modelMassage ++:find()
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: massages
controllersMassages <-- modelMassage --:massages
controllersMassages->client --:response

newpage

' ==========================================
' GET ONE
' ==========================================
== Manage Massage (GET One) ==

client->server ++:req.get('/api/massages/:id')
server->routerMassages ++:app.use('/api/massages',massages)
routerMassages -> controllersMassages ++:getMassage()
controllersMassages->modelMassage ++:findById(req.params.id)
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: massage
controllersMassages <-- modelMassage --:massage
controllersMassages->client --:response

newpage

' ==========================================
' PUT (UPDATE)
' ==========================================
== Manage Massage (PUT) ==

client->server ++:req.put('/api/massages/:id')
server->routerMassages ++:app.use('/api/massages',massages)
routerMassages -> controllersMassages ++:updateMassage()
controllersMassages->modelMassage ++:findByIdAndUpdate(req.params.id, req.body)
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: massage
controllersMassages <-- modelMassage --:massage
controllersMassages->client --:response

newpage

' ==========================================
' DELETE
' ==========================================
== Manage Massage (DELETE) ==

client->server ++:req.delete('/api/massages/:id')
server->routerMassages ++:app.use('/api/massages',massages)
routerMassages -> controllersMassages ++:deleteMassage()
controllersMassages->modelMassage ++:findById(req.params.id)
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: massage
controllersMassages <-- modelMassage --:massage
controllersMassages->modelMassage ++:deleteOne()
modelMassage ->MassagesDatabase ++: MassageSchema
MassagesDatabase --> modelMassage --: void
controllersMassages <-- modelMassage --:void
controllersMassages->client --:response

@enduml
